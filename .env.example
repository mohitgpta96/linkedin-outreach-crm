# ── LinkedIn Outreach Intelligence Tool — Environment Variables ──
#
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to git.

# Apify (free $5/month)
# Get at: https://console.apify.com → Settings → API & Integrations
APIFY_TOKEN=your_apify_token_here

# RapidAPI (free tier, no credit card needed)
# Get at: https://rapidapi.com → sign up → dashboard
RAPIDAPI_KEY=your_rapidapi_key_here

# Supabase (free PostgreSQL, 500MB)
# Get at: https://supabase.com → New Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
